---
// AI Agent Demo — standalone page, no BaseLayout
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI Agent Demo — Birky Studio</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style is:inline>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; background: #0f172a; color: #fff; min-height: 100vh; display: flex; flex-direction: column; }
    .demo-bar { background: linear-gradient(135deg, #6366f1, #ec4899); padding: 10px 20px; text-align: center; font-size: 0.82rem; font-weight: 600; letter-spacing: 0.5px; }
    .demo-bar span { opacity: 0.9; }
    .header { background: #1e293b; padding: 16px 20px; display: flex; align-items: center; gap: 12px; border-bottom: 1px solid #334155; flex-wrap: wrap; }
    .avatar { width: 44px; height: 44px; border-radius: 50%; background: linear-gradient(135deg, #10b981, #059669); display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
    .header-info { flex: 1; min-width: 0; }
    .header-info h1 { font-size: 1rem; font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .header-info p { font-size: 0.75rem; color: #10b981; margin-top: 2px; }
    .lang-toggle { flex-shrink: 0; display: flex; background: #334155; border-radius: 8px; overflow: hidden; }
    .lang-btn { padding: 6px 12px; border: none; background: transparent; color: #94a3b8; font-size: 0.78rem; font-weight: 600; cursor: pointer; font-family: 'Inter', sans-serif; }
    .lang-btn.active { background: #6366f1; color: #fff; }
    .chat { flex: 1; overflow-y: auto; padding: 20px 16px; display: flex; flex-direction: column; gap: 12px; max-height: calc(100vh - 220px); }
    .msg { max-width: 82%; padding: 12px 16px; border-radius: 18px; font-size: 0.92rem; line-height: 1.6; animation: fadeIn 0.3s ease; }
    .msg.bot { background: #1e293b; color: #e2e8f0; border-bottom-left-radius: 6px; align-self: flex-start; }
    .msg.user { background: #6366f1; color: #fff; border-bottom-right-radius: 6px; align-self: flex-end; }
    .msg .time { display: block; font-size: 0.68rem; color: #64748b; margin-top: 6px; text-align: right; }
    .msg.user .time { color: rgba(255,255,255,0.6); }
    .typing { background: #1e293b; color: #64748b; border-bottom-left-radius: 6px; align-self: flex-start; padding: 12px 16px; border-radius: 18px; font-size: 0.92rem; }
    .typing span { display: inline-block; width: 6px; height: 6px; background: #64748b; border-radius: 50%; margin: 0 2px; animation: bounce 1.4s infinite; }
    .typing span:nth-child(2) { animation-delay: 0.2s; }
    .typing span:nth-child(3) { animation-delay: 0.4s; }
    .quick-replies { display: flex; flex-wrap: wrap; gap: 8px; padding: 0 16px 12px; }
    .quick-btn { padding: 8px 16px; border: 1px solid #334155; border-radius: 100px; background: #1e293b; color: #a5b4fc; font-size: 0.82rem; font-weight: 500; cursor: pointer; font-family: 'Inter', sans-serif; transition: all 0.2s; }
    .quick-btn:hover { background: #334155; border-color: #6366f1; }
    .input-area { background: #1e293b; padding: 12px 16px; display: flex; gap: 10px; align-items: center; border-top: 1px solid #334155; }
    .input-area input { flex: 1; background: #0f172a; border: 1px solid #334155; border-radius: 24px; padding: 12px 18px; color: #e2e8f0; font-size: 0.92rem; font-family: 'Inter', sans-serif; outline: none; }
    .input-area input:focus { border-color: #6366f1; }
    .input-area input::placeholder { color: #475569; }
    .send-btn { width: 44px; height: 44px; border-radius: 50%; background: #6366f1; border: none; color: #fff; font-size: 1.2rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.2s; }
    .send-btn:hover { background: #4f46e5; }
    .footer-note { text-align: center; padding: 12px; font-size: 0.72rem; color: #475569; border-top: 1px solid #1e293b; }
    .footer-note a { color: #818cf8; text-decoration: none; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes bounce { 0%, 60%, 100% { transform: translateY(0); } 30% { transform: translateY(-6px); } }
  </style>
</head>
<body>

<div class="demo-bar">
  <span>🤖 This is a LIVE DEMO of our AI Agent — try asking it anything!</span>
</div>

<div class="header">
  <div class="avatar">🍽</div>
  <div class="header-info">
    <h1>Restaurante La Montaña</h1>
    <p>● online — AI Receptionist</p>
  </div>
  <div class="lang-toggle">
    <button class="lang-btn active" onclick="setLang('en')">EN</button>
    <button class="lang-btn" onclick="setLang('es')">ES</button>
  </div>
</div>

<div class="chat" id="chat"></div>

<div class="quick-replies" id="quickReplies"></div>

<div class="input-area">
  <input type="text" id="userInput" placeholder="Type a message..." autocomplete="off">
  <button class="send-btn" onclick="sendMessage()">➤</button>
</div>

<div class="footer-note">
  Powered by <a href="https://birkystudio.com">Birky Studio</a> — AI Agent Setup for Small Businesses
</div>

<script is:inline>
let currentLang = 'en';
let isTyping = false;

const knowledge = {
  en: {
    greeting: "👋 Welcome to Restaurante La Montaña! I'm your AI assistant. I can help with our menu, hours, reservations, location, and more. What would you like to know?",
    responses: {
      hours: "🕐 We're open every day!\n\n• Monday - Thursday: 11:00 AM - 9:00 PM\n• Friday - Saturday: 11:00 AM - 10:30 PM\n• Sunday: 10:00 AM - 9:00 PM (Brunch from 10!)\n\nOur kitchen closes 30 minutes before closing time.",
      menu: "📋 Our menu features Guatemalan fusion cuisine:\n\n🥗 **Starters** — Q35-65\n• Chirmol dip with handmade tortillas\n• Black bean soup with crema\n• Guacamole with local herbs\n\n🥘 **Mains** — Q75-145\n• Pepián (traditional chicken stew)\n• Grilled ribeye with chimichurri\n• Catch of the day with coconut rice\n• Vegetarian stuffed peppers\n\n🍰 **Desserts** — Q40-55\n• Rellenitos with chocolate sauce\n• Tres leches cake\n\nWould you like to see the full menu or make a reservation?",
      vegetarian: "🌱 Yes! We have great vegetarian options:\n\n• Stuffed poblano peppers with rice & beans\n• Vegetable pepián (our signature!)\n• Grilled portobello with mole sauce\n• Black bean burger with chipotle mayo\n• Fresh salads with local produce\n\nWe can also make most dishes vegan on request. Just let your server know!",
      reservation: "📅 I'd love to help you book a table!\n\nPlease tell me:\n1. How many people?\n2. What date and time?\n3. Any special occasion?\n\nI'll check availability and confirm your reservation. You can also call us at +502 1234 5678.",
      location: "📍 We're located at:\n\n**5a Calle Poniente #12, Antigua Guatemala**\n(2 blocks west of Parque Central)\n\n🚗 **Parking:** Free parking available in our lot behind the restaurant (enter from 6a Calle).\n\n🚌 **From Guatemala City:** Take the Antigua shuttle to the Terminal, we're a 10-minute walk.\n\n[View on Google Maps](https://maps.google.com)",
      price: "💰 Our prices are very reasonable:\n\n• Appetizers: Q35-65 ($4-8)\n• Main courses: Q75-145 ($10-19)\n• Desserts: Q40-55 ($5-7)\n• Drinks: Q25-65 ($3-8)\n\nAverage spend per person: Q150-200 ($20-26)\n\nWe accept cash (Quetzales & USD), credit cards, and Bitcoin!",
      drinks: "🍹 Our bar serves:\n\n• Craft cocktails with local spirits (Q55-75)\n• Guatemalan craft beers (Q30-40)\n• Wine selection (from Q45/glass)\n• Fresh juices & smoothies (Q25-35)\n• Coffee from Antigua's finest farms (Q20-30)\n\nHappy Hour: 4-6 PM daily — 2x1 on cocktails! 🎉",
      wifi: "📶 Yes, we have free WiFi for all customers!\n\n**Network:** LaMontana_Guest\n**Password:** bienvenidos2026\n\nEnjoy your stay! 😊",
      delivery: "🚗 Yes! We offer delivery within Antigua:\n\n• **Free delivery** on orders over Q200\n• Q25 delivery fee for smaller orders\n• Delivery time: 30-45 minutes\n\nTo order, just tell me what you'd like or call +502 1234 5678.\n\nWe're also on Hugo and PedidosYa!",
      event: "🎉 We host private events!\n\n• **Private dining room** — up to 20 people\n• **Terrace** — up to 50 people (volcano view! 🌋)\n• **Full restaurant buyout** — up to 80 people\n\nPerfect for birthdays, corporate dinners, weddings, and celebrations. We offer custom menus and open bar packages.\n\nWould you like me to send you our events brochure?",
      default: "I'm not sure I understood that question. Here's what I can help with:\n\n• 🕐 Opening hours\n• 📋 Menu & prices\n• 🌱 Vegetarian options\n• 📅 Reservations\n• 📍 Location & parking\n• 🍹 Drinks menu\n• 📶 WiFi password\n• 🚗 Delivery\n• 🎉 Private events\n\nJust ask about any of these!"
    },
    quickReplies: ["What are your hours?", "Show me the menu", "Make a reservation", "Where are you located?"],
    inputPlaceholder: "Type a message..."
  },
  es: {
    greeting: "👋 ¡Bienvenido a Restaurante La Montaña! Soy tu asistente de IA. Puedo ayudarte con nuestro menú, horarios, reservaciones, ubicación y más. ¿Qué te gustaría saber?",
    responses: {
      hours: "🕐 ¡Estamos abiertos todos los días!\n\n• Lunes - Jueves: 11:00 AM - 9:00 PM\n• Viernes - Sábado: 11:00 AM - 10:30 PM\n• Domingo: 10:00 AM - 9:00 PM (¡Brunch desde las 10!)\n\nLa cocina cierra 30 minutos antes del cierre.",
      menu: "📋 Nuestro menú ofrece fusión guatemalteca:\n\n🥗 **Entrantes** — Q35-65\n• Dip de chirmol con tortillas artesanales\n• Sopa de frijol negros con crema\n• Guacamole con hierbas locales\n\n🥘 **Platos principales** — Q75-145\n• Pepián (estofado tradicional de pollo)\n• Ribeye a la parrilla con chimichurri\n• Pescado del día con arroz de coco\n• Pimientos rellenos vegetarianos\n\n🍰 **Postres** — Q40-55\n• Rellenitos con salsa de chocolate\n• Pastel de tres leches\n\n¿Te gustaría ver el menú completo o hacer una reservación?",
      vegetarian: "🌱 ¡Sí! Tenemos excelentes opciones vegetarianas:\n\n• Pimientos poblanos rellenos con arroz y frijoles\n• Pepián de verduras (¡nuestra especialidad!)\n• Portobello a la parrilla con mole\n• Hamburguesa de frijol negros con mayonesa chipotle\n• Ensaladas frescas con productos locales\n\nTambién podemos hacer la mayoría de platos veganos bajo pedido. ¡Solo dile a tu mesero!",
      reservation: "📅 ¡Me encantaría ayudarte a reservar una mesa!\n\nPor favor dime:\n1. ¿Cuántas personas?\n2. ¿Qué fecha y hora?\n3. ¿Alguna ocasión especial?\n\nVeré la disponibilidad y confirmaré tu reservación. También puedes llamarnos al +502 1234 5678.",
      location: "📍 Estamos ubicados en:\n\n**5a Calle Poniente #12, Antigua Guatemala**\n(2 cuadras al oeste del Parque Central)\n\n🚗 **Estacionamiento:** Estacionamiento gratis disponible en nuestro lote detrás del restaurante (entrada por 6a Calle).\n\n🚌 **Desde Guatemala City:** Toma el shuttle a la Terminal, estamos a 10 minutos caminando.\n\n[Ver en Google Maps](https://maps.google.com)",
      price: "💰 Nuestros precios son muy accesibles:\n\n• Entrantes: Q35-65\n• Platos principales: Q75-145\n• Postres: Q40-55\n• Bebidas: Q25-65\n\nGasto promedio por persona: Q150-200\n\n¡Aceptamos efectivo (Quetzales y dólares), tarjetas de crédito y Bitcoin!",
      drinks: "🍹 Nuestro bar sirve:\n\n• Cócteles artesanales con licores locales (Q55-75)\n• Cervezas artesanales guatemaltecas (Q30-40)\n• Selección de vinos (desde Q45/copa)\n• Jugos frescos y smoothies (Q25-35)\n• Café de las mejores fincas de Antigua (Q20-30)\n\nHappy Hour: 4-6 PM diario — ¡2x1 en cócteles! 🎉",
      wifi: "📶 ¡Sí, tenemos WiFi gratis para todos los clientes!\n\n**Red:** LaMontana_Guest\n**Contraseña:** bienvenidos2026\n\n¡Disfruta tu estancia! 😊",
      delivery: "🚗 ¡Sí! Ofrecemos delivery dentro de Antigua:\n\n• **Delivery gratis** en pedidos sobre Q200\n• Q25 de envío para pedidos menores\n• Tiempo de entrega: 30-45 minutos\n\nPara ordenar, dime qué te gustaría o llama al +502 1234 5678.\n\n¡También estamos en Hugo y PedidosYa!",
      event: "🎉 ¡Hacemos eventos privados!\n\n• **Sala privada** — hasta 20 personas\n• **Terraza** — hasta 50 personas (¡con vista al volcán! 🌋)\n• **Restaurante completo** — hasta 80 personas\n\nPerfecto para cumpleaños, cenas corporativas, bodas y celebraciones. Ofrecemos menús personalizados y paquetes de barra libre.\n\n¿Te gustaría que te envíe nuestro brochure de eventos?",
      default: "No estoy seguro de haber entendido. Puedo ayudarte con:\n\n• 🕐 Horarios\n• 📋 Menú y precios\n• 🌱 Opciones vegetarianas\n• 📅 Reservaciones\n• 📍 Ubicación y estacionamiento\n• 🍹 Menú de bebidas\n• 📶 Contraseña WiFi\n• 🚗 Delivery\n• 🎉 Eventos privados\n\n¡Pregunta sobre cualquiera de estos!"
    },
    quickReplies: ["¿Cuáles son sus horarios?", "Muéstrame el menú", "Hacer una reservación", "¿Dónde están ubicados?"],
    inputPlaceholder: "Escribe un mensaje..."
  }
};

function matchIntent(text) {
  const t = text.toLowerCase();
  if (/\b(hours?|horarios?|open|close|cierran|abren|what time|a qué hora|when|cuando)\b/i.test(t)) return 'hours';
  if (/\b(menu|menú|food|comida|platillos?|dishes?|eat|comer|qué sirven|what do you serve)\b/i.test(t)) return 'menu';
  if (/\b(vegan|vegetarian|veggie|sin carne|plant based|verduras)\b/i.test(t)) return 'vegetarian';
  if (/\b(reserva|reserv|book|table|mesa|reserve|apartar)\b/i.test(t) || /reservation|reservación|reservacion/i.test(t)) return 'reservation';
  if (/\b(where|location|ubicaci|direcci|address|dónde|parking|estacion|map|maps|como llego)\b/i.test(t)) return 'location';
  if (/\b(price|prices?|cost|cuanto|cuesta|cuánto|presupuesto|budget|expensive|barato|cheap)\b/i.test(t)) return 'price';
  if (/\b(drink|cocktail|beer|wine|bar|cerveza|vino|trago|bebida|coctel|happy hour)\b/i.test(t)) return 'drinks';
  if (/\b(wifi|wi-fi|internet|password|contraseña|clave)\b/i.test(t)) return 'wifi';
  if (/\b(delivery|deliver|domicilio|envio|envío|pedido|order|hugo|pedidosya|takeout|take out|para llevar)\b/i.test(t)) return 'delivery';
  if (/\b(event|party|private|boda|wedding|birthday|cumpleaños|corporate|grupo|group|privado|fiesta)\b/i.test(t)) return 'event';
  return 'default';
}

function getTime() {
  return new Date().toLocaleTimeString(currentLang === 'en' ? 'en-US' : 'es-GT', { hour: '2-digit', minute: '2-digit' });
}

function addMessage(text, sender) {
  const chat = document.getElementById('chat');
  const msg = document.createElement('div');
  msg.className = `msg ${sender}`;
  msg.innerHTML = text.replace(/\n/g, '<br>').replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>') + `<span class="time">${getTime()}</span>`;
  chat.appendChild(msg);
  chat.scrollTop = chat.scrollHeight;
}

function showTyping() {
  const chat = document.getElementById('chat');
  const typing = document.createElement('div');
  typing.className = 'typing';
  typing.id = 'typing';
  typing.innerHTML = '<span></span><span></span><span></span>';
  chat.appendChild(typing);
  chat.scrollTop = chat.scrollHeight;
}

function hideTyping() {
  const typing = document.getElementById('typing');
  if (typing) typing.remove();
}

function sendMessage(text) {
  if (isTyping) return;
  const input = document.getElementById('userInput');
  const message = text || input.value.trim();
  if (!message) return;
  if (!text) input.value = '';
  addMessage(message, 'user');
  document.getElementById('quickReplies').innerHTML = '';
  isTyping = true;
  showTyping();
  const delay = 800 + Math.random() * 1200;
  setTimeout(() => {
    hideTyping();
    const intent = matchIntent(message);
    const response = knowledge[currentLang].responses[intent];
    addMessage(response, 'bot');
    isTyping = false;
    setTimeout(() => showQuickReplies(), 500);
  }, delay);
}

function showQuickReplies() {
  const container = document.getElementById('quickReplies');
  const replies = knowledge[currentLang].quickReplies;
  container.innerHTML = replies.map(r =>
    `<button class="quick-btn" onclick="sendMessage('${r}')">${r}</button>`
  ).join('');
}

function setLang(lang) {
  currentLang = lang;
  document.querySelectorAll('.lang-btn').forEach(btn => {
    btn.classList.toggle('active', btn.textContent.trim() === lang.toUpperCase());
  });
  document.getElementById('userInput').placeholder = knowledge[lang].inputPlaceholder;
  const chat = document.getElementById('chat');
  chat.innerHTML = '';
  addMessage(knowledge[lang].greeting, 'bot');
  showQuickReplies();
}

document.getElementById('userInput').addEventListener('keydown', (e) => {
  if (e.key === 'Enter') sendMessage();
});

setLang('en');
</script>

</body>
</html>
