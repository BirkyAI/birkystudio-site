---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Inicio" description="Soluciones digitales inteligentes para negocios locales — sitios web profesionales y agentes de IA, entregados rápido y construidos para crecer contigo.">
  
  <!-- Hero Section -->
  <section style="background:linear-gradient(135deg,#0f172a 0%,#1e1b4b 50%,#312e81 100%);padding:120px 0 100px;position:relative;overflow:hidden;">
    <div style="position:absolute;top:0;left:0;right:0;bottom:0;background:radial-gradient(circle at 20% 50%,rgba(99,102,241,0.15),transparent 50%),radial-gradient(circle at 80% 50%,rgba(236,72,153,0.1),transparent 50%);"></div>
    <div class="container" style="position:relative;z-index:1;text-align:center;">
      <div style="width:120px;height:120px;border-radius:50%;overflow:hidden;border:4px solid rgba(255,255,255,0.2);margin:0 auto 20px;box-shadow:0 0 40px rgba(99,102,241,0.3);">
        <img src="/images/birky-mascot.jpg" alt="Birky - mascota de Birky Studio" style="width:100%;height:100%;object-fit:cover;">
      </div>
      <div style="display:inline-block;padding:8px 20px;background:rgba(255,255,255,0.1);border-radius:100px;color:#a5b4fc;font-size:0.9rem;font-weight:500;margin-bottom:24px;">
        🚀 Sitios Web + Agentes IA • Entrega rápida • Precios accesibles
      </div>
      <h1 style="font-size:clamp(2.5rem,6vw,4.5rem);font-weight:800;color:white;margin-bottom:24px;max-width:900px;margin-left:auto;margin-right:auto;">
        Soluciones Digitales Para<br>
        <span style="background:linear-gradient(135deg,#818cf8,#f472b6,#22d3ee);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">Negocios Locales</span>
      </h1>
      <p style="font-size:1.25rem;color:#cbd5e1;max-width:600px;margin:0 auto 40px;line-height:1.8;">
        Sitios web profesionales que te traen clientes, y agentes de IA que se encargan del resto. Construido rápido, construido para durar.
      </p>
      <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
        <a href="/es/contacto" class="btn btn-primary" style="font-size:1.1rem;padding:18px 36px;">
          Cotización Gratis →
        </a>
        <a href="#productos" class="btn btn-secondary" style="background:transparent;color:white;border-color:rgba(255,255,255,0.3);font-size:1.1rem;padding:18px 36px;">
          Ver Productos
        </a>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <section style="background:white;padding:48px 0;border-bottom:1px solid #e2e8f0;">
    <div class="container">
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:24px;text-align:center;">
        <div>
          <div style="font-size:1.8rem;font-weight:800;background:var(--gradient-primary);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">2-3</div>
          <div style="color:var(--color-gray);font-size:0.95rem;margin-top:4px;">Días de entrega</div>
        </div>
        <div>
          <div style="font-size:1.8rem;font-weight:800;background:var(--gradient-primary);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">100%</div>
          <div style="color:var(--color-gray);font-size:0.95rem;margin-top:4px;">Optimizado para celular</div>
        </div>
        <div>
          <div style="font-size:1.8rem;font-weight:800;background:var(--gradient-primary);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">ES/EN</div>
          <div style="color:var(--color-gray);font-size:0.95rem;margin-top:4px;">Bilingüe</div>
        </div>
        <div>
          <div style="font-size:1.8rem;font-weight:800;background:var(--gradient-primary);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">24/7</div>
          <div style="color:var(--color-gray);font-size:0.95rem;margin-top:4px;">Siempre en línea</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Products Section -->
  <section id="productos" style="padding:100px 0;background:#f8fafc;">
    <div class="container">
      <div style="text-align:center;margin-bottom:64px;">
        <h2 style="font-size:2.5rem;margin-bottom:16px;">Nuestros Productos</h2>
        <p style="color:var(--color-gray);font-size:1.1rem;max-width:600px;margin:0 auto;">Dos soluciones poderosas para hacer crecer tu negocio — una presencia profesional en línea y automatización inteligente.</p>
      </div>
      
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(400px,1fr));gap:40px;max-width:900px;margin:0 auto;">
        <!-- Product 1: Website Design -->
        <div style="background:white;border-radius:24px;padding:48px;border:1px solid #e2e8f0;text-align:center;">
          <div style="width:80px;height:80px;background:linear-gradient(135deg,#818cf8,#6366f1);border-radius:20px;display:flex;align-items:center;justify-content:center;font-size:2rem;margin:0 auto 28px;">
            🌐
          </div>
          <h3 style="font-size:1.5rem;margin-bottom:16px;">Diseño de Sitios Web</h3>
          <p style="color:var(--color-gray);line-height:1.8;font-size:1.05rem;margin-bottom:28px;">
            Sitios web profesionales, optimizados para celular, que cargan rápido y convierten visitantes en clientes. Bilingües, con SEO e integración de WhatsApp — entregados en 2-3 días.
          </p>
          <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:28px;">
            <span style="padding:6px 14px;background:#f1f5f9;border-radius:100px;font-size:0.82rem;font-weight:500;color:var(--color-dark);">Mobile-First</span>
            <span style="padding:6px 14px;background:#f1f5f9;border-radius:100px;font-size:0.82rem;font-weight:500;color:var(--color-dark);">Bilingüe</span>
            <span style="padding:6px 14px;background:#f1f5f9;border-radius:100px;font-size:0.82rem;font-weight:500;color:var(--color-dark);">SEO</span>
            <span style="padding:6px 14px;background:#f1f5f9;border-radius:100px;font-size:0.82rem;font-weight:500;color:var(--color-dark);">WhatsApp</span>
            <span style="padding:6px 14px;background:#f1f5f9;border-radius:100px;font-size:0.82rem;font-weight:500;color:var(--color-dark);">Rápido</span>
          </div>
          <a href="#precios-sitios" class="btn btn-primary" style="display:inline-flex;">
            Ver Planes de Sitios →
          </a>
        </div>
        
        <!-- Product 2: AI Agent Setup -->
        <div style="background:white;border-radius:24px;padding:48px;border:1px solid #e2e8f0;text-align:center;">
          <div style="width:80px;height:80px;background:linear-gradient(135deg,#f472b6,#ec4899);border-radius:20px;display:flex;align-items:center;justify-content:center;font-size:2rem;margin:0 auto 28px;">
            🤖
          </div>
          <h3 style="font-size:1.5rem;margin-bottom:16px;">Agente de IA</h3>
          <p style="color:var(--color-gray);line-height:1.8;font-size:1.05rem;margin-bottom:28px;">
            Un asistente de IA dedicado a tu negocio — responde preguntas de clientes, gestiona tareas, automatiza trabajo repetitivo y te ayuda a mantener todo organizado. Funciona en WhatsApp, Telegram, correo y más.
          </p>
          <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:28px;">
            <span style="padding:6px 14px;background:#f1f5f9;border-radius:100px;font-size:0.82rem;font-weight:500;color:var(--color-dark);">Atención al Cliente</span>
            <span style="padding:6px 14px;background:#f1f5f9;border-radius:100px;font-size:0.82rem;font-weight:500;color:var(--color-dark);">Automatización</span>
            <span style="padding:6px 14px;background:#f1f5f9;border-radius:100px;font-size:0.82rem;font-weight:500;color:var(--color-dark);">Multi-Plataforma</span>
            <span style="padding:6px 14px;background:#f1f5f9;border-radius:100px;font-size:0.82rem;font-weight:500;color:var(--color-dark);">Bilingüe</span>
            <span style="padding:6px 14px;background:#f1f5f9;border-radius:100px;font-size:0.82rem;font-weight:500;color:var(--color-dark);">24/7</span>
          </div>
          <a href="#precios-ia" class="btn btn-primary" style="display:inline-flex;background:linear-gradient(135deg,#f472b6,#ec4899);box-shadow:0 4px 15px rgba(236,72,153,0.4);">
            Ver Planes de IA →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section style="padding:100px 0;background:white;">
    <div class="container">
      <div style="text-align:center;margin-bottom:64px;">
        <h2 style="font-size:2.5rem;margin-bottom:16px;">Cómo Funciona</h2>
        <p style="color:var(--color-gray);font-size:1.1rem;max-width:600px;margin:0 auto;">Tres pasos simples — sin importar qué producto elijas.</p>
      </div>
      
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:48px;">
        <div style="text-align:center;">
          <div style="width:80px;height:80px;background:var(--gradient-primary);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:2rem;font-weight:800;color:white;margin:0 auto 24px;">1</div>
          <h3 style="font-size:1.25rem;margin-bottom:12px;">Cuéntanos Lo Que Necesitas</h3>
          <p style="color:var(--color-gray);line-height:1.8;">Comparte los detalles y objetivos de tu negocio. Ya sea un sitio web, un asistente de IA, o ambos — te recomendaremos la solución correcta.</p>
        </div>
        
        <div style="text-align:center;">
          <div style="width:80px;height:80px;background:var(--gradient-accent);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:2rem;font-weight:800;color:white;margin:0 auto 24px;">2</div>
          <h3 style="font-size:1.25rem;margin-bottom:12px;">Lo Construimos Para Ti</h3>
          <p style="color:var(--color-gray);line-height:1.8;">Nuestro proceso impulsado por IA crea tu solución en solo 2-3 días. Tú revisas, das feedback y apruebas.</p>
        </div>
        
        <div style="text-align:center;">
          <div style="width:80px;height:80px;background:linear-gradient(135deg,#10b981,#059669);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:2rem;font-weight:800;color:white;margin:0 auto 24px;">3</div>
          <h3 style="font-size:1.25rem;margin-bottom:12px;">En Línea y Creciendo</h3>
          <p style="color:var(--color-gray);line-height:1.8;">Tu sitio está en vivo o tu agente de IA empieza a trabajar. Comparte el enlace, automatiza tareas y empieza a ver resultados.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing: Websites -->
  <section id="precios-sitios" style="padding:100px 0;background:linear-gradient(135deg,#0f172a 0%,#1e1b4b 100%);">
    <div class="container">
      <div style="text-align:center;margin-bottom:64px;">
        <div style="display:inline-block;padding:6px 16px;background:rgba(99,102,241,0.2);border-radius:100px;color:#a5b4fc;font-size:0.85rem;font-weight:600;margin-bottom:16px;">🌐 Diseño de Sitios Web</div>
        <h2 style="font-size:2.5rem;color:white;margin-bottom:16px;">Planes de Sitios Web</h2>
        <p style="color:#94a3b8;font-size:1.1rem;max-width:600px;margin:0 auto;">Sitios web profesionales a precios justos. Sin costos ocultos, sin sorpresas.</p>
      </div>
      
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:32px;max-width:1000px;margin:0 auto;">
        <!-- Starter -->
        <div style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:24px;padding:40px;backdrop-filter:blur(10px);">
          <h3 style="color:white;font-size:1.5rem;margin-bottom:8px;">Básico</h3>
          <p style="color:#94a3b8;margin-bottom:24px;">Perfecto para negocios nuevos</p>
          <div style="margin-bottom:32px;">
            <span style="font-size:2rem;font-weight:800;color:white;">Q1,500</span>
            <span style="color:#94a3b8;"> pago único</span>
          </div>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:16px;margin-bottom:32px;">
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;"><span style="color:#10b981;">✓</span> 1-3 páginas</li>
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;"><span style="color:#10b981;">✓</span> Responsivo para celular</li>
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;"><span style="color:#10b981;">✓</span> Botón de WhatsApp</li>
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;"><span style="color:#10b981;">✓</span> Google Maps</li>
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;"><span style="color:#10b981;">✓</span> Formulario de contacto</li>
          </ul>
          <a href="/es/contacto" class="btn btn-secondary" style="width:100%;justify-content:center;">Empezar</a>
        </div>
        
        <!-- Professional -->
        <div style="background:linear-gradient(135deg,rgba(99,102,241,0.2),rgba(236,72,153,0.2));border:2px solid rgba(99,102,241,0.5);border-radius:24px;padding:40px;position:relative;">
          <div style="position:absolute;top:-14px;left:50%;transform:translateX(-50%);background:var(--gradient-primary);color:white;padding:6px 20px;border-radius:100px;font-size:0.85rem;font-weight:600;">Más Popular</div>
          <h3 style="color:white;font-size:1.5rem;margin-bottom:8px;">Profesional</h3>
          <p style="color:#94a3b8;margin-bottom:24px;">Para negocios en crecimiento</p>
          <div style="margin-bottom:32px;">
            <span style="font-size:2rem;font-weight:800;color:white;">Q3,000</span>
            <span style="color:#94a3b8;"> pago único</span>
          </div>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:16px;margin-bottom:32px;">
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;"><span style="color:#10b981;">✓</span> 5-7 páginas</li>
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;"><span style="color:#10b981;">✓</span> Todo lo del plan Básico</li>
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;"><span style="color:#10b981;">✓</span> Bilingüe (ES/EN)</li>
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;"><span style="color:#10b981;">✓</span> Galería de fotos</li>
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;"><span style="color:#10b981;">✓</span> Optimización SEO</li>
          </ul>
          <a href="/es/contacto" class="btn btn-primary" style="width:100%;justify-content:center;">Empezar</a>
        </div>
        
        <!-- Premium -->
        <div style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:24px;padding:40px;backdrop-filter:blur(10px);">
          <h3 style="color:white;font-size:1.5rem;margin-bottom:8px;">Premium</h3>
          <p style="color:#94a3b8;margin-bottom:24px;">Para negocios establecidos</p>
          <div style="margin-bottom:32px;">
            <span style="font-size:2rem;font-weight:800;color:white;">Q6,000</span>
            <span style="color:#94a3b8;"> pago único</span>
          </div>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:16px;margin-bottom:32px;">
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;"><span style="color:#10b981;">✓</span> 10+ páginas</li>
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;"><span style="color:#10b981;">✓</span> Todo lo del plan Profesional</li>
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;"><span style="color:#10b981;">✓</span> Blog configurado</li>
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;"><span style="color:#10b981;">✓</span> Funciones personalizadas</li>
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;"><span style="color:#10b981;">✓</span> Soporte prioritario</li>
          </ul>
          <a href="/es/contacto" class="btn btn-secondary" style="width:100%;justify-content:center;">Empezar</a>
        </div>
      </div>
      
      <!-- Optional Add-on -->
      <div style="text-align:center;margin-top:48px;padding:32px;background:rgba(255,255,255,0.05);border-radius:16px;max-width:600px;margin-left:auto;margin-right:auto;">
        <p style="color:#94a3b8;font-size:0.95rem;">
          <strong style="color:white;">¿Quieres editar tu sitio tú mismo?</strong> Agrega nuestro editor fácil por solo <strong style="color:#818cf8;">Q1,000</strong> extra. Actualiza texto y fotos cuando quieras, sin saber programar.
        </p>
      </div>
    </div>
  </section>

  <!-- Pricing: AI Agent -->
  <section id="precios-ia" style="padding:100px 0;background:linear-gradient(135deg,#1a0f2e 0%,#2d1b4e 100%);">
    <div class="container">
      <div style="text-align:center;margin-bottom:64px;">
        <div style="display:inline-block;padding:6px 16px;background:rgba(236,72,153,0.2);border-radius:100px;color:#f9a8d4;font-size:0.85rem;font-weight:600;margin-bottom:16px;">🤖 Agente de IA</div>
        <h2 style="font-size:2.5rem;color:white;margin-bottom:16px;">Planes de Agente IA</h2>
        <p style="color:#94a3b8;font-size:1.1rem;max-width:600px;margin:0 auto;">Un asistente inteligente que trabaja 24/7 — para que tú no tengas que hacerlo.</p>
      </div>
      
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:32px;max-width:900px;margin:0 auto;">
        <!-- Starter Agent -->
        <div style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:24px;padding:40px;backdrop-filter:blur(10px);">
          <h3 style="color:white;font-size:1.5rem;margin-bottom:8px;">Agente Básico</h3>
          <p style="color:#94a3b8;margin-bottom:24px;">Para negocios pequeños que empiezan</p>
          <div style="margin-bottom:32px;">
            <span style="font-size:2rem;font-weight:800;color:white;">Q2,000</span>
            <span style="color:#94a3b8;"> configuración única</span>
          </div>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:16px;margin-bottom:32px;">
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;"><span style="color:#10b981;">✓</span> 1 plataforma (WhatsApp o Telegram)</li>
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;"><span style="color:#10b981;">✓</span> Respuestas a preguntas frecuentes</li>
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;"><span style="color:#10b981;">✓</span> Automatización básica de tareas</li>
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;"><span style="color:#10b981;">✓</span> Bilingüe (ES/EN)</li>
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;"><span style="color:#10b981;">✓</span> Configuración y entrenamiento incluido</li>
          </ul>
          <a href="/es/contacto" class="btn btn-secondary" style="width:100%;justify-content:center;">Empezar</a>
        </div>
        
        <!-- Pro Agent -->
        <div style="background:linear-gradient(135deg,rgba(236,72,153,0.2),rgba(99,102,241,0.2));border:2px solid rgba(236,72,153,0.5);border-radius:24px;padding:40px;position:relative;">
          <div style="position:absolute;top:-14px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,#f472b6,#ec4899);color:white;padding:6px 20px;border-radius:100px;font-size:0.85rem;font-weight:600;">Más Popular</div>
          <h3 style="color:white;font-size:1.5rem;margin-bottom:8px;">Agente Pro</h3>
          <p style="color:#94a3b8;margin-bottom:24px;">Para negocios que quieren automatización completa</p>
          <div style="margin-bottom:32px;">
            <span style="font-size:2rem;font-weight:800;color:white;">Q4,000</span>
            <span style="color:#94a3b8;"> configuración única</span>
          </div>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:16px;margin-bottom:32px;">
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;"><span style="color:#10b981;">✓</span> Multi-plataforma (WhatsApp + Telegram + Email)</li>
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;"><span style="color:#10b981;">✓</span> Todo lo del plan Básico</li>
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;"><span style="color:#10b981;">✓</span> Flujos de trabajo personalizados</li>
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;"><span style="color:#10b981;">✓</span> Gestión de calendario y tareas</li>
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;"><span style="color:#10b981;">✓</span> Soporte y actualizaciones continuas</li>
          </ul>
          <a href="/es/contacto" class="btn btn-primary" style="width:100%;justify-content:center;background:linear-gradient(135deg,#f472b6,#ec4899);box-shadow:0 4px 15px rgba(236,72,153,0.4);">Empezar</a>
        </div>
