      <!-- Note -->
      <div style="text-align:center;margin-top:48px;padding:32px;background:rgba(255,255,255,0.05);border-radius:16px;max-width:700px;margin-left:auto;margin-right:auto;">
        <p style="color:#94a3b8;font-size:0.95rem;">
          <strong style="color:white;">¿Necesitas algo personalizado?</strong> Cada negocio es diferente. <a href="/es/contacto" style="color:#f9a8d4;text-decoration:underline;">Contáctanos</a> para una solución de agente IA diseñada específicamente para tu flujo de trabajo.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section style="padding:100px 0;background:white;">
