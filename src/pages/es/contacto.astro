---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Contacto" description="Contáctanos para empezar tu proyecto de sitio web. Respuesta rápida, cotización gratis.">
  
  <section style="padding:100px 0;background:linear-gradient(135deg,#0f172a 0%,#1e1b4b 100%);">
    <div class="container" style="text-align:center;">
      <div style="width:90px;height:90px;border-radius:50%;overflow:hidden;border:3px solid rgba(255,255,255,0.2);margin:0 auto 20px;box-shadow:0 0 30px rgba(99,102,241,0.3);">
        <img src="/images/birky-mascot.jpg" alt="Birky - mascota de Birky Studio" style="width:100%;height:100%;object-fit:cover;">
      </div>
      <h1 style="font-size:clamp(2rem,5vw,3.5rem);color:white;margin-bottom:16px;">Construyamos Algo Genial</h1>
      <p style="color:#94a3b8;font-size:1.1rem;max-width:600px;margin:0 auto;">Cuéntanos sobre tu negocio y te responderemos en menos de 24 horas con una cotización gratis.</p>
    </div>
  </section>

  <section style="padding:80px 0;background:#f8fafc;">
    <div class="container">
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:64px;max-width:1000px;margin:0 auto;">
        <!-- Contact Form -->
        <div style="background:white;border-radius:24px;padding:48px;box-shadow:0 4px 20px rgba(0,0,0,0.08);">
          <h2 style="font-size:1.5rem;margin-bottom:32px;">Envíanos un Mensaje</h2>
          <form name="contact-es" method="POST" data-netlify="true" style="display:flex;flex-direction:column;gap:20px;">
            <input type="hidden" name="form-name" value="contact-es">
            <div>
              <label style="display:block;font-weight:500;margin-bottom:8px;color:var(--color-dark);">Tu Nombre</label>
              <input type="text" name="name" required style="width:100%;padding:14px 16px;border:2px solid #e2e8f0;border-radius:12px;font-size:1rem;" placeholder="Juan Pérez">
            </div>
            <div>
              <label style="display:block;font-weight:500;margin-bottom:8px;color:var(--color-dark);">Correo Electrónico</label>
              <input type="email" name="email" required style="width:100%;padding:14px 16px;border:2px solid #e2e8f0;border-radius:12px;font-size:1rem;" placeholder="juan@negocio.com">
            </div>
            <div>
              <label style="display:block;font-weight:500;margin-bottom:8px;color:var(--color-dark);">Nombre del Negocio</label>
              <input type="text" name="business" style="width:100%;padding:14px 16px;border:2px solid #e2e8f0;border-radius:12px;font-size:1rem;" placeholder="Tu Negocio">
            </div>
            <div>
              <label style="display:block;font-weight:500;margin-bottom:8px;color:var(--color-dark);">¿Qué necesitas?</label>
              <select name="service" style="width:100%;padding:14px 16px;border:2px solid #e2e8f0;border-radius:12px;font-size:1rem;background:white;">
                <option value="basico">Sitio Básico (Q1,500)</option>
                <option value="profesional">Sitio Profesional (Q3,000)</option>
                <option value="premium">Sitio Premium (Q6,000)</option>
                <option value="nosure">No estoy seguro/a</option>
              </select>
            </div>
            <div>
              <label style="display:block;font-weight:500;margin-bottom:8px;color:var(--color-dark);">Cuéntanos más</label>
              <textarea name="message" rows="4" style="width:100%;padding:14px 16px;border:2px solid #e2e8f0;border-radius:12px;font-size:1rem;resize:vertical;" placeholder="¿A qué se dedica tu negocio? ¿Alguna función específica que necesites?"></textarea>
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;font-size:1.1rem;padding:16px;">
              Enviar Mensaje →
            </button>
          </form>
        </div>
        
        <!-- Contact Info -->
        <div style="display:flex;flex-direction:column;gap:32px;">
          <div>
            <h3 style="font-size:1.25rem;margin-bottom:16px;">Contáctanos Directo</h3>
            <p style="color:var(--color-gray);line-height:1.8;margin-bottom:24px;">¿Prefieres escribirnos directo? Estamos disponibles en WhatsApp y correo. Normalmente respondemos en unas horas.</p>
          </div>
          
          <div style="background:white;border-radius:16px;padding:24px;border:1px solid #e2e8f0;">
            <div style="display:flex;align-items:center;gap:16px;">
              <div style="width:48px;height:48px;background:linear-gradient(135deg,#25d366,#128c7e);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;">💬</div>
              <div>
                <div style="font-weight:600;margin-bottom:4px;">WhatsApp</div>
                <div style="color:var(--color-gray);">+502 3571 6181</div>
              </div>
            </div>
          </div>
          
          <div style="background:white;border-radius:16px;padding:24px;border:1px solid #e2e8f0;">
            <div style="display:flex;align-items:center;gap:16px;">
              <div style="width:48px;height:48px;background:var(--gradient-primary);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;">📧</div>
              <div>
                <div style="font-weight:600;margin-bottom:4px;">Correo</div>
                <div style="color:var(--color-gray);">birky.ai@proton.me</div>
              </div>
            </div>
          </div>
          
          <div style="background:white;border-radius:16px;padding:24px;border:1px solid #e2e8f0;">
            <div style="display:flex;align-items:center;gap:16px;">
              <div style="width:48px;height:48px;background:linear-gradient(135deg,#06b6d4,#0891b2);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;">⏰</div>
              <div>
                <div style="font-weight:600;margin-bottom:4px;">Tiempo de Respuesta</div>
                <div style="color:var(--color-gray);">Menos de 24 horas</div>
              </div>
            </div>
          </div>
          
          <div style="background:linear-gradient(135deg,#818cf8,#6366f1);border-radius:16px;padding:24px;color:white;">
            <h4 style="margin-bottom:8px;">Cotización Gratis</h4>
            <p style="opacity:0.9;line-height:1.6;">¿No sabes qué necesitas? Cuéntanos sobre tu negocio y te recomendamos el paquete ideal para ti. Sin compromiso.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>