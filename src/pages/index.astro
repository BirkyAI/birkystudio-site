---
import BaseLayout from '../layouts/BaseLayout.astro';

const organizationLD = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Birky Studio",
  "url": "https://birkystudio.com",
  "logo": "https://birkystudio.com/images/birky-mascot.jpg",
  "description": "Smart digital solutions for small businesses — professional websites and AI agents, delivered fast and built to grow with you.",
  "email": "birky.ai@proton.me",
  "telephone": "+50235716181",
  "areaServed": "Worldwide",
  "serviceType": ["Web Design", "AI Agent Setup"],
  "sameAs": [],
  "offers": [
    {
      "@type": "Offer",
      "name": "Starter Website",
      "price": "195",
      "priceCurrency": "USD"
    },
    {
      "@type": "Offer",
      "name": "Professional Website",
      "price": "390",
      "priceCurrency": "USD"
    },
    {
      "@type": "Offer",
      "name": "Premium Website",
      "price": "780",
      "priceCurrency": "USD"
    }
  ]
});
---

<BaseLayout title="Birky Studio — Websites & AI Agents for Small Businesses" description="Professional websites and AI agents for small businesses. Bilingual sites delivered in 2-3 days, AI receptionists that work 24/7. Affordable pricing, real results.">
  <script type="application/ld+json" set:html={organizationLD} />
  
  <!-- Hero Section -->
  <section style="background:linear-gradient(135deg,#0f172a 0%,#1e1b4b 50%,#312e81 100%);padding:120px 0 100px;position:relative;overflow:hidden;">
    <div style="position:absolute;top:0;left:0;right:0;bottom:0;background:radial-gradient(circle at 20% 50%,rgba(99,102,241,0.15),transparent 50%),radial-gradient(circle at 80% 50%,rgba(236,72,153,0.1),transparent 50%);"></div>
    <div style="max-width:1400px;margin:0 auto;padding:0 48px;position:relative;z-index:1;display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center;" class="hero-grid">
      <!-- Left: Text -->
      <div>
        <div style="width:80px;height:80px;border-radius:50%;overflow:hidden;border:3px solid rgba(255,255,255,0.2);margin-bottom:20px;box-shadow:0 0 30px rgba(99,102,241,0.3);">
          <img src="/images/birky-mascot.jpg" alt="Birky - Birky Studio mascot" style="width:100%;height:100%;object-fit:cover;">
        </div>
        <div style="display:inline-block;padding:8px 20px;background:rgba(255,255,255,0.1);border-radius:100px;color:#a5b4fc;font-size:0.85rem;font-weight:500;margin-bottom:20px;">
          🚀 Websites + AI Agents • Fast delivery • Affordable pricing
        </div>
        <h1 style="font-size:clamp(2rem,4vw,3.5rem);font-weight:800;color:white;margin-bottom:20px;line-height:1.15;">
          Smart Digital Solutions For<br>
          <span style="background:linear-gradient(135deg,#818cf8,#f472b6,#22d3ee);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">Small Businesses</span>
        </h1>
        <p style="font-size:1.15rem;color:#cbd5e1;margin-bottom:32px;line-height:1.8;max-width:500px;">
          Professional websites that bring you customers, and AI agents that handle the rest. Built fast, built to last.
        </p>
        <div style="display:flex;gap:14px;flex-wrap:wrap;">
          <a href="/contact" class="btn btn-primary" style="font-size:1.05rem;padding:16px 32px;">
            Get Started →
          </a>
          <a href="/#products" class="btn btn-secondary" style="background:transparent;color:white;border-color:rgba(255,255,255,0.3);font-size:1.05rem;padding:16px 32px;">
            View Products
          </a>
        </div>
      </div>

      <!-- Right: AI Demo -->
      <div style="border-radius:16px;overflow:hidden;box-shadow:0 24px 80px rgba(0,0,0,0.4);border:1px solid rgba(255,255,255,0.1);">
        <div style="background:#1e293b;padding:10px 16px;display:flex;align-items:center;gap:8px;">
          <div style="display:flex;gap:5px;">
            <div style="width:9px;height:9px;border-radius:50%;background:#ef4444;"></div>
            <div style="width:9px;height:9px;border-radius:50%;background:#eab308;"></div>
            <div style="width:9px;height:9px;border-radius:50%;background:#22c55e;"></div>
          </div>
          <div style="flex:1;background:#334155;border-radius:6px;padding:3px 10px;color:#94a3b8;font-size:0.7rem;font-family:monospace;text-align:center;">
            AI Agent — Live Demo
          </div>
        </div>
        <iframe src="/ai-demo" style="width:100%;height:480px;border:none;display:block;" title="AI Agent Demo" loading="eager"></iframe>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <section style="background:white;padding:48px 0;border-bottom:1px solid #e2e8f0;">
    <div class="container">
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:24px;text-align:center;">
        <div>
          <div style="font-size:1.8rem;font-weight:800;background:var(--gradient-primary);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">2-3</div>
          <div style="color:var(--color-gray);font-size:0.95rem;margin-top:4px;">Days to deliver</div>
        </div>
        <div>
          <div style="font-size:1.8rem;font-weight:800;background:var(--gradient-primary);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">100%</div>
          <div style="color:var(--color-gray);font-size:0.95rem;margin-top:4px;">Mobile friendly</div>
        </div>
        <div>
