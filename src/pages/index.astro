---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home" description="Smart Websites For Small Businesses - Fast, professional web design for local businesses worldwide.">
  
  <!-- Hero Section -->
  <section style="background:linear-gradient(135deg,#0f172a 0%,#1e1b4b 50%,#312e81 100%);padding:120px 0 100px;position:relative;overflow:hidden;">
    <div style="position:absolute;top:0;left:0;right:0;bottom:0;background:radial-gradient(circle at 20% 50%,rgba(99,102,241,0.15),transparent 50%),radial-gradient(circle at 80% 50%,rgba(236,72,153,0.1),transparent 50%);"></div>
    <div class="container" style="position:relative;z-index:1;text-align:center;">
      <div style="width:120px;height:120px;border-radius:50%;overflow:hidden;border:4px solid rgba(255,255,255,0.2);margin:0 auto 20px;box-shadow:0 0 40px rgba(99,102,241,0.3);">
        <img src="/images/birky-mascot.jpg" alt="Birky - Birky Studio mascot" style="width:100%;height:100%;object-fit:cover;">
      </div>
      <div style="display:inline-block;padding:8px 20px;background:rgba(255,255,255,0.1);border-radius:100px;color:#a5b4fc;font-size:0.9rem;font-weight:500;margin-bottom:24px;">
        🚀 Fast delivery • Professional design • Affordable pricing
      </div>
      <h1 style="font-size:clamp(2.5rem,6vw,4.5rem);font-weight:800;color:white;margin-bottom:24px;max-width:900px;margin-left:auto;margin-right:auto;">
        Smart Websites For<br>
        <span style="background:linear-gradient(135deg,#818cf8,#f472b6,#22d3ee);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">Small Businesses</span>
      </h1>
      <p style="font-size:1.25rem;color:#cbd5e1;max-width:600px;margin:0 auto 40px;line-height:1.8;">
        Get a professional website in just 2-3 days. Mobile-friendly, bilingual, and designed to bring you more customers.
      </p>
      <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
        <a href="/contact" class="btn btn-primary" style="font-size:1.1rem;padding:18px 36px;">
          Get Your Website →
        </a>
        <a href="/#pricing" class="btn btn-secondary" style="background:transparent;color:white;border-color:rgba(255,255,255,0.3);font-size:1.1rem;padding:18px 36px;">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <section style="background:white;padding:48px 0;border-bottom:1px solid #e2e8f0;">
    <div class="container">
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:24px;text-align:center;">
        <div>
          <div style="font-size:1.8rem;font-weight:800;background:var(--gradient-primary);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">2-3</div>
          <div style="color:var(--color-gray);font-size:0.95rem;margin-top:4px;">Days to deliver</div>
        </div>
        <div>
          <div style="font-size:1.8rem;font-weight:800;background:var(--gradient-primary);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">100%</div>
          <div style="color:var(--color-gray);font-size:0.95rem;margin-top:4px;">Mobile friendly</div>
        </div>
        <div>
          <div style="font-size:1.8rem;font-weight:800;background:var(--gradient-primary);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">EN/ES</div>
          <div style="color:var(--color-gray);font-size:0.95rem;margin-top:4px;">Bilingual ready</div>
        </div>
        <div>
          <div style="font-size:1.8rem;font-weight:800;background:var(--gradient-primary);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">24/7</div>
          <div style="color:var(--color-gray);font-size:0.95rem;margin-top:4px;">Always online</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" style="padding:100px 0;background:#f8fafc;">
    <div class="container">
      <div style="text-align:center;margin-bottom:64px;">
        <h2 style="font-size:2.5rem;margin-bottom:16px;">What You Get</h2>
        <p style="color:var(--color-gray);font-size:1.1rem;max-width:600px;margin:0 auto;">Everything your business needs to succeed online, delivered fast and built to last.</p>
      </div>
      
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:32px;">
        <!-- Service 1 -->
        <div style="background:white;border-radius:20px;padding:40px;border:1px solid #e2e8f0;transition:all 0.3s;">
          <div style="width:60px;height:60px;background:linear-gradient(135deg,#818cf8,#6366f1);border-radius:16px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;margin-bottom:24px;">
            📱
          </div>
          <h3 style="font-size:1.25rem;margin-bottom:12px;">Mobile-First Design</h3>
          <p style="color:var(--color-gray);line-height:1.8;">Looks perfect on every device. Most of your customers are searching on their phones — your site needs to work flawlessly.</p>
        </div>
        
        <!-- Service 2 -->
        <div style="background:white;border-radius:20px;padding:40px;border:1px solid #e2e8f0;transition:all 0.3s;">
          <div style="width:60px;height:60px;background:linear-gradient(135deg,#f472b6,#ec4899);border-radius:16px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;margin-bottom:24px;">
            💬
          </div>
          <h3 style="font-size:1.25rem;margin-bottom:12px;">WhatsApp Integration</h3>
          <p style="color:var(--color-gray);line-height:1.8;">One-tap WhatsApp button so customers can reach you instantly. Because that's how business works.</p>
        </div>
        
        <!-- Service 3 -->
        <div style="background:white;border-radius:20px;padding:40px;border:1px solid #e2e8f0;transition:all 0.3s;">
          <div style="width:60px;height:60px;background:linear-gradient(135deg,#22d3ee,#06b6d4);border-radius:16px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;margin-bottom:24px;">
            🌍
          </div>
          <h3 style="font-size:1.25rem;margin-bottom:12px;">Bilingual Ready</h3>
          <p style="color:var(--color-gray);line-height:1.8;">English and Spanish versions of your site. Reach more customers in any market.</p>
        </div>
        
        <!-- Service 4 -->
        <div style="background:white;border-radius:20px;padding:40px;border:1px solid #e2e8f0;transition:all 0.3s;">
          <div style="width:60px;height:60px;background:linear-gradient(135deg,#a78bfa,#8b5cf6);border-radius:16px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;margin-bottom:24px;">
            📍
          </div>
          <h3 style="font-size:1.25rem;margin-bottom:12px;">Google Maps</h3>
          <p style="color:var(--color-gray);line-height:1.8;">Interactive map showing your location. Customers can get directions with one click.</p>
        </div>
        
        <!-- Service 5 -->
        <div style="background:white;border-radius:20px;padding:40px;border:1px solid #e2e8f0;transition:all 0.3s;">
          <div style="width:60px;height:60px;background:linear-gradient(135deg,#34d399,#10b981);border-radius:16px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;margin-bottom:24px;">
            ⚡
          </div>
          <h3 style="font-size:1.25rem;margin-bottom:12px;">Lightning Fast</h3>
          <p style="color:var(--color-gray);line-height:1.8;">Built with modern technology that loads in under 2 seconds. Fast sites rank higher on Google.</p>
        </div>
        
        <!-- Service 6 -->
        <div style="background:white;border-radius:20px;padding:40px;border:1px solid #e2e8f0;transition:all 0.3s;">
          <div style="width:60px;height:60px;background:linear-gradient(135deg,#fb923c,#f97316);border-radius:16px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;margin-bottom:24px;">
            🔒
          </div>
          <h3 style="font-size:1.25rem;margin-bottom:12px;">Free SSL Security</h3>
          <p style="color:var(--color-gray);line-height:1.8;">HTTPS encryption included. Your customers see the secure lock icon. Trust matters.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section style="padding:100px 0;background:white;">
    <div class="container">
      <div style="text-align:center;margin-bottom:64px;">
        <h2 style="font-size:2.5rem;margin-bottom:16px;">How It Works</h2>
        <p style="color:var(--color-gray);font-size:1.1rem;max-width:600px;margin:0 auto;">Three simple steps to your new website.</p>
      </div>
      
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:48px;">
        <div style="text-align:center;">
          <div style="width:80px;height:80px;background:var(--gradient-primary);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:2rem;font-weight:800;color:white;margin:0 auto 24px;">1</div>
          <h3 style="font-size:1.25rem;margin-bottom:12px;">Tell Us About Your Business</h3>
          <p style="color:var(--color-gray);line-height:1.8;">Fill out a simple form with your business details, photos, and what you need. Takes 10 minutes.</p>
        </div>
        
        <div style="text-align:center;">
          <div style="width:80px;height:80px;background:var(--gradient-accent);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:2rem;font-weight:800;color:white;margin:0 auto 24px;">2</div>
          <h3 style="font-size:1.25rem;margin-bottom:12px;">We Build Your Site</h3>
          <p style="color:var(--color-gray);line-height:1.8;">Our AI-powered process creates your professional website in just 2-3 days. You review and approve.</p>
        </div>
        
        <div style="text-align:center;">
          <div style="width:80px;height:80px;background:linear-gradient(135deg,#10b981,#059669);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:2rem;font-weight:800;color:white;margin:0 auto 24px;">3</div>
          <h3 style="font-size:1.25rem;margin-bottom:12px;">Go Live & Get Customers</h3>
          <p style="color:var(--color-gray);line-height:1.8;">Your site goes live. Share the link, add it to your Google Business Profile, and start getting inquiries.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Section -->
  <section id="pricing" style="padding:100px 0;background:linear-gradient(135deg,#0f172a 0%,#1e1b4b 100%);">
    <div class="container">
      <div style="text-align:center;margin-bottom:64px;">
        <h2 style="font-size:2.5rem;color:white;margin-bottom:16px;">Simple, Transparent Pricing</h2>
        <p style="color:#94a3b8;font-size:1.1rem;max-width:600px;margin:0 auto;">No hidden fees. No surprises. Just great websites at fair prices.</p>
      </div>
      
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:32px;max-width:1000px;margin:0 auto;">
        <!-- Starter -->
        <div style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:24px;padding:40px;backdrop-filter:blur(10px);">
          <h3 style="color:white;font-size:1.5rem;margin-bottom:8px;">Starter</h3>
          <p style="color:#94a3b8;margin-bottom:24px;">Perfect for new businesses</p>
          <div style="margin-bottom:32px;">
            <span style="font-size:3rem;font-weight:800;color:white;">$195</span>
            <span style="color:#94a3b8;"> one-time</span>
          </div>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:16px;margin-bottom:32px;">
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;">
              <span style="color:#10b981;">✓</span> 1-3 pages
            </li>
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;">
              <span style="color:#10b981;">✓</span> Mobile responsive
            </li>
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;">
              <span style="color:#10b981;">✓</span> WhatsApp button
            </li>
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;">
              <span style="color:#10b981;">✓</span> Google Maps
            </li>
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;">
              <span style="color:#10b981;">✓</span> Contact form
            </li>
          </ul>
          <a href="/contact" class="btn btn-secondary" style="width:100%;justify-content:center;">Get Started</a>
        </div>
        
        <!-- Professional -->
        <div style="background:linear-gradient(135deg,rgba(99,102,241,0.2),rgba(236,72,153,0.2));border:2px solid rgba(99,102,241,0.5);border-radius:24px;padding:40px;position:relative;">
          <div style="position:absolute;top:-14px;left:50%;transform:translateX(-50%);background:var(--gradient-primary);color:white;padding:6px 20px;border-radius:100px;font-size:0.85rem;font-weight:600;">Most Popular</div>
          <h3 style="color:white;font-size:1.5rem;margin-bottom:8px;">Professional</h3>
          <p style="color:#94a3b8;margin-bottom:24px;">For growing businesses</p>
          <div style="margin-bottom:32px;">
            <span style="font-size:3rem;font-weight:800;color:white;">$390</span>
            <span style="color:#94a3b8;"> one-time</span>
          </div>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:16px;margin-bottom:32px;">
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;">
              <span style="color:#10b981;">✓</span> 5-7 pages
            </li>
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;">
              <span style="color:#10b981;">✓</span> Everything in Starter
            </li>
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;">
              <span style="color:#10b981;">✓</span> Bilingual (EN/ES)
            </li>
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;">
              <span style="color:#10b981;">✓</span> Photo gallery
            </li>
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;">
              <span style="color:#10b981;">✓</span> SEO optimization
            </li>
          </ul>
          <a href="/contact" class="btn btn-primary" style="width:100%;justify-content:center;">Get Started</a>
        </div>
        
        <!-- Premium -->
        <div style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:24px;padding:40px;backdrop-filter:blur(10px);">
          <h3 style="color:white;font-size:1.5rem;margin-bottom:8px;">Premium</h3>
          <p style="color:#94a3b8;margin-bottom:24px;">For established businesses</p>
          <div style="margin-bottom:32px;">
            <span style="font-size:3rem;font-weight:800;color:white;">$780</span>
            <span style="color:#94a3b8;"> one-time</span>
          </div>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:16px;margin-bottom:32px;">
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;">
              <span style="color:#10b981;">✓</span> 10+ pages
            </li>
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;">
              <span style="color:#10b981;">✓</span> Everything in Professional
            </li>
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;">
              <span style="color:#10b981;">✓</span> Blog setup
            </li>
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;">
              <span style="color:#10b981;">✓</span> Custom features
            </li>
            <li style="color:#cbd5e1;display:flex;align-items:center;gap:12px;">
              <span style="color:#10b981;">✓</span> Priority support
            </li>
          </ul>
          <a href="/contact" class="btn btn-secondary" style="width:100%;justify-content:center;">Get Started</a>
        </div>
      </div>
      
      <!-- Optional Add-on -->
      <div style="text-align:center;margin-top:48px;padding:32px;background:rgba(255,255,255,0.05);border-radius:16px;max-width:600px;margin-left:auto;margin-right:auto;">
        <p style="color:#94a3b8;font-size:0.95rem;">
          <strong style="color:white;">Need to edit your site yourself?</strong> Add our self-editing CMS for just <strong style="color:#818cf8;">$130</strong> one-time. Update text and photos anytime without coding.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section style="padding:100px 0;background:white;">
    <div class="container" style="text-align:center;">
      <h2 style="font-size:2.5rem;margin-bottom:16px;">Ready to Get Online?</h2>
      <p style="color:var(--color-gray);font-size:1.1rem;max-width:600px;margin:0 auto 40px;">Your competitors are already online. Let's make sure customers find you first.</p>
      <a href="/contact" class="btn btn-primary" style="font-size:1.1rem;padding:18px 36px;">
        Start Your Project →
      </a>
    </div>
  </section>

</BaseLayout>
