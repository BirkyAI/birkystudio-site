          <div style="color:var(--color-gray);font-size:0.95rem;margin-top:4px;">Bilingual ready</div>
        </div>
        <div>
          <div style="font-size:1.8rem;font-weight:800;background:var(--gradient-primary);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">24/7</div>
          <div style="color:var(--color-gray);font-size:0.95rem;margin-top:4px;">Always online</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Products Section -->
  <section id="products" style="padding:100px 0;background:#f8fafc;">
    <div class="container">
      <div style="text-align:center;margin-bottom:64px;">
        <h2 style="font-size:2.5rem;margin-bottom:16px;">Our Products</h2>
        <p style="color:var(--color-gray);font-size:1.1rem;max-width:600px;margin:0 auto;">Two powerful solutions to help your business grow — a professional online presence and smart automation.</p>
      </div>
      
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(400px,1fr));gap:40px;max-width:900px;margin:0 auto;">
        <!-- Product 1: Website Design -->
        <div style="background:white;border-radius:24px;padding:48px;border:1px solid #e2e8f0;transition:all 0.3s;text-align:center;display:flex;flex-direction:column;">
          <div style="width:80px;height:80px;background:linear-gradient(135deg,#818cf8,#6366f1);border-radius:20px;display:flex;align-items:center;justify-content:center;font-size:2rem;margin:0 auto 28px;">
            🌐
          </div>
          <h3 style="font-size:1.5rem;margin-bottom:16px;">Website Design</h3>
          <p style="color:var(--color-gray);line-height:1.8;font-size:1.05rem;margin-bottom:28px;">
            Professional, mobile-first websites that load fast and convert visitors into customers. Bilingual, SEO-optimized, with WhatsApp integration — everything your business needs to stand out online, delivered in 2-3 days.
          </p>
          <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:28px;">
            <span style="padding:6px 14px;background:#f1f5f9;border-radius:100px;font-size:0.82rem;font-weight:500;color:var(--color-dark);">Mobile-First</span>
            <span style="padding:6px 14px;background:#f1f5f9;border-radius:100px;font-size:0.82rem;font-weight:500;color:var(--color-dark);">Bilingual</span>
            <span style="padding:6px 14px;background:#f1f5f9;border-radius:100px;font-size:0.82rem;font-weight:500;color:var(--color-dark);">SEO</span>
            <span style="padding:6px 14px;background:#f1f5f9;border-radius:100px;font-size:0.82rem;font-weight:500;color:var(--color-dark);">WhatsApp</span>
            <span style="padding:6px 14px;background:#f1f5f9;border-radius:100px;font-size:0.82rem;font-weight:500;color:var(--color-dark);">Fast Loading</span>
