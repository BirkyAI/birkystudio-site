---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog'))
  .filter(post => post.data.lang === 'en')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title="Blog" description="Tips, guides, and insights on web design, AI automation, and growing your small business online.">

  <!-- Hero -->
  <section style="background:linear-gradient(135deg,#0f172a 0%,#1e1b4b 50%,#312e81 100%);padding:100px 0 80px;position:relative;overflow:hidden;">
    <div style="position:absolute;top:0;left:0;right:0;bottom:0;background:radial-gradient(circle at 20% 50%,rgba(99,102,241,0.15),transparent 50%),radial-gradient(circle at 80% 50%,rgba(236,72,153,0.1),transparent 50%);"></div>
    <div class="container" style="position:relative;z-index:1;text-align:center;">
      <div style="display:inline-block;padding:8px 20px;background:rgba(255,255,255,0.1);border-radius:100px;color:#a5b4fc;font-size:0.9rem;font-weight:500;margin-bottom:24px;">
        📝 Tips, guides & insights for your business
      </div>
      <h1 style="font-size:clamp(2.2rem,5vw,3.5rem);font-weight:800;color:white;margin-bottom:20px;">
        The <span style="background:linear-gradient(135deg,#818cf8,#f472b6,#22d3ee);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">Birky Studio</span> Blog
      </h1>
      <p style="font-size:1.2rem;color:#cbd5e1;max-width:600px;margin:0 auto;line-height:1.8;">
        Practical advice on websites, AI automation, and digital marketing — everything you need to grow your business online.
      </p>
    </div>
  </section>

  <!-- Blog Grid -->
  <section style="padding:80px 0;background:#f8fafc;">
    <div class="container">
      {allPosts.length === 0 ? (
        <div style="text-align:center;padding:80px 0;">
          <p style="color:var(--color-gray);font-size:1.1rem;">Blog posts coming soon! Check back later.</p>
        </div>
      ) : (
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:32px;">
          {allPosts.map((post) => (
            <a href={`/blog/${post.id}`} style="display:block;background:white;border-radius:20px;overflow:hidden;border:1px solid #e2e8f0;transition:all 0.3s;text-decoration:none;color:inherit;" class="blog-card">
              {post.data.image && (
                <div style="height:200px;overflow:hidden;">
                  <img src={post.data.image} alt={post.data.title} style="width:100%;height:100%;object-fit:cover;transition:transform 0.3s;" loading="lazy" />
                </div>
              )}
              <div style="padding:28px;">
                <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;">
                  <time style="color:var(--color-gray);font-size:0.85rem;">{formatDate(post.data.date)}</time>
                  {post.data.tags.length > 0 && (
                    <span style="padding:4px 10px;background:var(--color-light);border-radius:100px;font-size:0.75rem;font-weight:600;color:var(--color-primary);">
                      {post.data.tags[0]}
                    </span>
                  )}
                </div>
                <h2 style="font-size:1.25rem;margin-bottom:12px;line-height:1.4;">{post.data.title}</h2>
                <p style="color:var(--color-gray);font-size:0.95rem;line-height:1.7;">{post.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- CTA -->
  <section style="padding:80px 0;background:white;text-align:center;">
    <div class="container">
      <h2 style="font-size:2rem;margin-bottom:16px;">Ready to Get Started?</h2>
      <p style="color:var(--color-gray);font-size:1.05rem;max-width:500px;margin:0 auto 32px;">Let's build something great for your business — a website, an AI agent, or both.</p>
      <a href="/contact" class="btn btn-primary" style="font-size:1.1rem;padding:16px 32px;">Start Your Project →</a>
    </div>
  </section>

  <style>
    .blog-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 40px rgba(0,0,0,0.1);
    }
    .blog-card:hover img {
      transform: scale(1.05);
    }
  </style>
</BaseLayout>
